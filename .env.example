# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration (MySQL)
# 1. Create a MySQL database named 'movierecsysweb'
# 2. Update credentials below
DB_NAME=movierecsysweb
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Email Configuration (SMTP)
# Required for 2FA and Signup OTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Third-Party APIs
# Get your free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# Admin Permissions
# This email will have permanent super-admin access
BOSS_EMAIL=your-admin-email@gmail.com
